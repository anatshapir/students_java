<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.4"?>
<plugin>
   <!-- Extension points for views -->
   <extension point="org.eclipse.ui.views">
      <category
            id="com.javaedu.eclipse.category"
            name="JavaEdu">
      </category>
      <view
            id="com.javaedu.eclipse.views.ExerciseListView"
            name="Exercises"
            icon="icons/exercise.png"
            category="com.javaedu.eclipse.category"
            class="com.javaedu.eclipse.views.ExerciseListView"
            allowMultiple="false">
      </view>
      <view
            id="com.javaedu.eclipse.views.ExerciseDetailView"
            name="Exercise Details"
            icon="icons/detail.png"
            category="com.javaedu.eclipse.category"
            class="com.javaedu.eclipse.views.ExerciseDetailView"
            allowMultiple="false">
      </view>
      <view
            id="com.javaedu.eclipse.views.GradesView"
            name="My Grades"
            icon="icons/grades.png"
            category="com.javaedu.eclipse.category"
            class="com.javaedu.eclipse.views.GradesView"
            allowMultiple="false">
      </view>
      <view
            id="com.javaedu.eclipse.views.AIHelperView"
            name="AI Helper"
            icon="icons/ai.png"
            category="com.javaedu.eclipse.category"
            class="com.javaedu.eclipse.views.AIHelperView"
            allowMultiple="false">
      </view>
   </extension>

   <!-- Extension points for commands -->
   <extension point="org.eclipse.ui.commands">
      <category
            id="com.javaedu.eclipse.commands.category"
            name="JavaEdu Commands">
      </category>
      <command
            id="com.javaedu.eclipse.commands.login"
            name="Login to JavaEdu"
            categoryId="com.javaedu.eclipse.commands.category">
      </command>
      <command
            id="com.javaedu.eclipse.commands.logout"
            name="Logout from JavaEdu"
            categoryId="com.javaedu.eclipse.commands.category">
      </command>
      <command
            id="com.javaedu.eclipse.commands.submit"
            name="Submit Solution"
            categoryId="com.javaedu.eclipse.commands.category">
      </command>
      <command
            id="com.javaedu.eclipse.commands.runTests"
            name="Run Tests Locally"
            categoryId="com.javaedu.eclipse.commands.category">
      </command>
      <command
            id="com.javaedu.eclipse.commands.getHint"
            name="Get Hint"
            categoryId="com.javaedu.eclipse.commands.category">
      </command>
      <command
            id="com.javaedu.eclipse.commands.refreshExercises"
            name="Refresh Exercises"
            categoryId="com.javaedu.eclipse.commands.category">
      </command>
   </extension>

   <!-- Command handlers -->
   <extension point="org.eclipse.ui.handlers">
      <handler
            class="com.javaedu.eclipse.handlers.LoginHandler"
            commandId="com.javaedu.eclipse.commands.login">
      </handler>
      <handler
            class="com.javaedu.eclipse.handlers.LogoutHandler"
            commandId="com.javaedu.eclipse.commands.logout">
      </handler>
      <handler
            class="com.javaedu.eclipse.handlers.SubmitHandler"
            commandId="com.javaedu.eclipse.commands.submit">
      </handler>
      <handler
            class="com.javaedu.eclipse.handlers.RunTestsHandler"
            commandId="com.javaedu.eclipse.commands.runTests">
      </handler>
      <handler
            class="com.javaedu.eclipse.handlers.AskHintHandler"
            commandId="com.javaedu.eclipse.commands.getHint">
      </handler>
   </extension>

   <!-- Menu contributions -->
   <extension point="org.eclipse.ui.menus">
      <menuContribution locationURI="menu:org.eclipse.ui.main.menu?after=additions">
         <menu
               id="com.javaedu.eclipse.menu"
               label="JavaEdu"
               mnemonic="J">
            <command
                  commandId="com.javaedu.eclipse.commands.login"
                  label="Login..."
                  mnemonic="L">
            </command>
            <command
                  commandId="com.javaedu.eclipse.commands.logout"
                  label="Logout"
                  mnemonic="O">
            </command>
            <separator name="com.javaedu.eclipse.separator1"/>
            <command
                  commandId="com.javaedu.eclipse.commands.submit"
                  label="Submit Solution"
                  mnemonic="S">
            </command>
            <command
                  commandId="com.javaedu.eclipse.commands.runTests"
                  label="Run Tests Locally"
                  mnemonic="T">
            </command>
            <command
                  commandId="com.javaedu.eclipse.commands.getHint"
                  label="Get Hint"
                  mnemonic="H">
            </command>
            <separator name="com.javaedu.eclipse.separator2"/>
            <command
                  commandId="com.javaedu.eclipse.commands.refreshExercises"
                  label="Refresh Exercises"
                  mnemonic="R">
            </command>
         </menu>
      </menuContribution>

      <!-- Toolbar contribution -->
      <menuContribution locationURI="toolbar:org.eclipse.ui.main.toolbar?after=additions">
         <toolbar id="com.javaedu.eclipse.toolbar">
            <command
                  commandId="com.javaedu.eclipse.commands.submit"
                  icon="icons/submit.png"
                  label="Submit"
                  tooltip="Submit current solution">
            </command>
            <command
                  commandId="com.javaedu.eclipse.commands.runTests"
                  icon="icons/test.png"
                  label="Test"
                  tooltip="Run tests locally">
            </command>
         </toolbar>
      </menuContribution>
   </extension>

   <!-- Perspective extension -->
   <extension point="org.eclipse.ui.perspectiveExtensions">
      <perspectiveExtension targetID="org.eclipse.jdt.ui.JavaPerspective">
         <viewShortcut id="com.javaedu.eclipse.views.ExerciseListView"/>
         <viewShortcut id="com.javaedu.eclipse.views.ExerciseDetailView"/>
         <viewShortcut id="com.javaedu.eclipse.views.GradesView"/>
         <viewShortcut id="com.javaedu.eclipse.views.AIHelperView"/>
         <view
               id="com.javaedu.eclipse.views.ExerciseListView"
               ratio="0.3"
               relationship="left"
               relative="org.eclipse.ui.views.ContentOutline">
         </view>
      </perspectiveExtension>
   </extension>

   <!-- Preferences -->
   <extension point="org.eclipse.ui.preferencePages">
      <page
            class="com.javaedu.eclipse.preferences.JavaEduPreferencePage"
            id="com.javaedu.eclipse.preferences"
            name="JavaEdu">
      </page>
   </extension>

   <extension point="org.eclipse.core.runtime.preferences">
      <initializer class="com.javaedu.eclipse.preferences.PreferenceInitializer"/>
   </extension>
</plugin>
