# ===========================================
# JavaEdu Server - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# --- Database (PostgreSQL, production) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=javaedu
DB_USERNAME=javaedu
DB_PASSWORD=change-me

# --- Server ---
SERVER_PORT=8080

# --- JWT / Encryption ---
# Must be at least 32 characters. Used for auth tokens AND encrypting sensitive DB fields.
JWT_SECRET=change-me-to-a-random-32-char-string

# --- AI (Claude API) ---
AI_PROVIDER=claude
AI_API_KEY=sk-ant-...

# --- Google OAuth / Classroom ---
# Get these from https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:5173/auth/google/callback

# --- GitHub OAuth (optional) ---
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
